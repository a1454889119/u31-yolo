@export conv1_96in_48out_whc
conv1_96in_48out_whc:
	mov outptr outadr
	lcs d2_lo 0xc840
	simd_ext32 kscale layer_scale
	simd_ext32 kzero_point layer_zeropt
	// 设置ptr0偏移值为wxh
	lc j 0x10000
	or i wxh j
	svw 0x09000058, i

	lcs inputc 96
	$jump_regs rj0, rj1
	lcs i 0
	whileu i < wxh {
		mov bptr badr
		mov kptr kadr
		mov inptr inadr
		mov outptr outadr
		lcs j 0
		whileu j < 48 {

			lm_d b_03 bptr
			CONV_16(b0)
			CONV_16(b0)
			CONV_16(b0)
			CONV_16(b0)
			CONV_16(b0)
			CONV_16(b0)

			mov inptr inadr
			CONV_16(b1)
			CONV_16(b1)
			CONV_16(b1)
			CONV_16(b1)
			CONV_16(b1)
			CONV_16(b1)

			mov inptr inadr
			CONV_16(b2)
			CONV_16(b2)
			CONV_16(b2)
			CONV_16(b2)
			CONV_16(b2)
			CONV_16(b2)

			mov inptr inadr
			CONV_16(b3)
			CONV_16(b3)
			CONV_16(b3)
			CONV_16(b3)
			CONV_16(b3)
			CONV_16(b3)

			inc j 4
			mov inptr inadr

			simd_leaky d0 b_03 mulshift
			simd_16to32 b_03 d0
			simd_i32f32 b_03 b_03 31
			simd_fmul b_03 b_03 kscale
			simd_fsub b_03 b_03 kzero_point
			simd_f32i32 ktmp b_03 30
			simd_f32i32 b_03 b_03 31
			simd_sub32 b_03 ktmp b_03
			nop

			sbyte outptr b0
			sbyte outptr b1
			sbyte outptr b2
			sbyte outptr b3
		}
		inc outadr 1
		inc inadr inputc
		inc i 1
	}
	$jump_regs end
	// ptr0 偏移值写回0
	svw 0x09000058 0
	ret

