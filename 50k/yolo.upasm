#include "yolo_size.upinc"
#include "yolo.upinc"
#include "u31_sys_macros.upinc"

@import layer_16_psram_adr

@import layer_0
@import layer_1
@import layer_2
@import layer_3
@import layer_16
@import layer_4
@import layer_5
@import layer_6
@import layer_7
