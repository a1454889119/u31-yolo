@export data_120x160
$func transpos_120x160(in input, in output)
	

entry:
	svw 0x09000040 3
	transpos_120x160(data_120x160, data_160x120)
	lvw r0 0x09000040
	hlt

#define src_ptr ptr4
#define dst0_ptr ptr0
#define dst1_ptr ptr1
#define dst2_ptr ptr2
#define dst3_ptr ptr3
$func transpos_120x160(in input, in output) {
	reg h, i, j, dst_adr

	lcs h 160
	load_reg src_ptr input
	load_reg dst_adr output


	sl i 1 16
	lcs j, 160*4
	or i i j

	svw 0x09000058 i
	svw 0x0900005c i
	svw 0x09000060 i
	svw 0x09000064 i
	
	lcs i, 0
	whileu i < h {
		add dst0_ptr dst_adr i
		add dst1_ptr dst0_ptr h
		add dst2_ptr dst1_ptr h
		add dst3_ptr dst2_ptr h
	
		// 3*32 + 16 + 8 = 120
		repeat_sta 3
pixels_32:
			lm_d s6 src_ptr
			lm_d s7 src_ptr
			simd_8to32 s4 s6_0
			simd_8to32 s5 s6_1
			sbyte dst0_ptr s4_0
			sbyte dst1_ptr s4_1
			sbyte dst2_ptr s4_2
			sbyte dst3_ptr s4_3
			sbyte dst0_ptr s5_0
			sbyte dst1_ptr s5_1
			sbyte dst2_ptr s5_2
			sbyte dst3_ptr s5_3

			simd_8to32 s4 s6_2
			simd_8to32 s5 s6_3
			sbyte dst0_ptr s4_0
			sbyte dst1_ptr s4_1
			sbyte dst2_ptr s4_2
			sbyte dst3_ptr s4_3
			sbyte dst0_ptr s5_0
			sbyte dst1_ptr s5_1
			sbyte dst2_ptr s5_2
			sbyte dst3_ptr s5_3

			simd_8to32 s4 s7_0
			simd_8to32 s5 s7_1
			sbyte dst0_ptr s4_0
			sbyte dst1_ptr s4_1
			sbyte dst2_ptr s4_2
			sbyte dst3_ptr s4_3
			sbyte dst0_ptr s5_0
			sbyte dst1_ptr s5_1
			sbyte dst2_ptr s5_2
			sbyte dst3_ptr s5_3

			simd_8to32 s4 s7_2
			simd_8to32 s5 s7_3
			sbyte dst0_ptr s4_0
			sbyte dst1_ptr s4_1
			sbyte dst2_ptr s4_2
			sbyte dst3_ptr s4_3
			sbyte dst0_ptr s5_0
			sbyte dst1_ptr s5_1
			sbyte dst2_ptr s5_2
			sbyte dst3_ptr s5_3
		repeat_end pixels_32

		lm_d s6 src_ptr
		l64_d s7_01 src_ptr
		simd_8to32 s4 s6_0
		simd_8to32 s5 s6_1
		sbyte dst0_ptr s4_0
		sbyte dst1_ptr s4_1
		sbyte dst2_ptr s4_2
		sbyte dst3_ptr s4_3
		sbyte dst0_ptr s5_0
		sbyte dst1_ptr s5_1
		sbyte dst2_ptr s5_2
		sbyte dst3_ptr s5_3

		simd_8to32 s4 s6_2
		simd_8to32 s5 s6_3
		sbyte dst0_ptr s4_0
		sbyte dst1_ptr s4_1
		sbyte dst2_ptr s4_2
		sbyte dst3_ptr s4_3
		sbyte dst0_ptr s5_0
		sbyte dst1_ptr s5_1
		sbyte dst2_ptr s5_2
		sbyte dst3_ptr s5_3

		simd_8to32 s4 s7_0
		simd_8to32 s5 s7_1
		sbyte dst0_ptr s4_0
		sbyte dst1_ptr s4_1
		sbyte dst2_ptr s4_2
		sbyte dst3_ptr s4_3
		sbyte dst0_ptr s5_0
		sbyte dst1_ptr s5_1
		sbyte dst2_ptr s5_2
		sbyte dst3_ptr s5_3

		inc i 1
	}

	svw 0x09000058 0
	svw 0x0900005c 0
	svw 0x09000060 0
	svw 0x09000064 0
	nop
}


data_120x160:
.reserve 120*160

data_160x120:
.reserve 160*120