.short 0xff45 0x016d 0 0 0 0 0 0
.short 0xff42 0x0107 0x00c2 0x00c1 0xffaf 0x012c 0x0000 0x0069 
.short 0xff99 0xff31 0xff15 0x0059 0x0163 0x00df 0xfdfc 0x000b 
.short 0x000a 0x0059 0 0 0 0 0 0
.short 0xff96 0xfe04 0xfeb0 0x025c 0xffee 0x0094 0xfe34 0xfe95 
