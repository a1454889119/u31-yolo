.short 0xfff2 0xff21 0 0 0 0 0 0
.short 0x00ab 0xff46 0xff50 0xff45 0xff7c 0x00f0 0x0001 0xffca 
.short 0xffd0 0xffb5 0x00e2 0x007a 0x0075 0x01bc 0x001d 0x019f 
.short 0xffd7 0xff25 0 0 0 0 0 0
.short 0xfdb0 0x00fc 0x00fd 0x0089 0xff3e 0x0124 0xffbc 0xfeff 
.short 0xff86 0x0010 0xff93 0x007b 0xfde3 0x008a 0xfef6 0x0052 
.short 0x0146 0x015c 0 0 0 0 0 0
