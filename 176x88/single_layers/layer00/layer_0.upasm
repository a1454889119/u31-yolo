.short 0xff43 0x045c 0xff34 0
.short 0x01ac 0x0092 0x0036 0x00e1 0x0068 0xffc3 0xff8e 0x007f 
.short 0x0006 0x043c 0xff53 0xffd8 0x0437 0xfe8b 0x0047 0x01af 
.short 0xfec9 0x0024 0xffc5 0x006a 0x007d 0xfde1 0x0056 0x0039 
.short 0xfe6d 0x0060 0x007a 0
.short 0x0547 0x00cd 0xfeb3 0xfb5e 0xfe87 0x010d 0xffb0 0xffa0 
.short 0x00a4 0x076f 0x00b6 0xfed4 0xf9c5 0xff98 0x0095 0xff3b 
.short 0x00d2 0x0058 0x02d7 0xfef8 0x0004 0xfd26 0x0069 0x005c 
.short 0x003d 0x00d4 0xff1b 0
.short 0x0190 0xff3f 0xff03 0x0530 0xfbca 0xfee4 0x01d7 0xff6f 
.short 0xff18 0x010b 0xfef4 0xffa1 0x0a8c 0xf84b 0xfcbb 0x04dd 
.short 0xfcb7 0xfeb0 0x028c 0xfe14 0xff8c 0x0386 0xfb4b 0x0101 
.short 0x039b 0xfc4d 0x001b 0
.short 0x00ec 0x013c 0xffb8 0x0222 0x01e5 0xfe6c 0xff85 0x01f3 
.short 0xfe0a 0x00a2 0xfe43 0x01c6 0x04b0 0xfec0 0x0151 0x0326 
.short 0xfff6 0xfeb7 0xfce6 0xfff0 0x012f 0xfdf6 0xff6c 0x01e5 
.short 0x0013 0x0044 0x00ab 0


