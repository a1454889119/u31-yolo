.short 0x00e5 0x01af 0x0102 0xffed 0x0047 0xff78 0xfec1 0xff36 
.short 0x00a2 0x0078 0x0074 0xffd1 0x0181 0x00c3 0xfe59 0x00fb 
.short 0xffc1 0x01d8 0xff94 0x00fd 0x01e0 0xfff8 0x012e 0x0047 
.short 0xfef2 0xff9a 0xffd4 0x0141 0xffde 0x0017 0xfe71 0x0078 
.short 0x00ed 0x0123 0xff88 0xfe52 0xffea 0x00e9 0x0047 0x0190 
.short 0x0025 0x006e 0xff84 0xfff4 0xffd8 0xff95 0xfff0 0x0240 
.short 0x023b 0x0019 0x003a 0x00c3 0xff4d 0xff24 0xfee9 0x00ba 
