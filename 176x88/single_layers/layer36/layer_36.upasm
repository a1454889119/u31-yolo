.word 0xffffa800 0x00022400 0xffff6400 0xfffe5800 
.word 0xfff35c00 0x00144000 0x00011000 0x0001a800 
.word 0x00035400 0xfffdf400 0xffec5c00 0x00144000 
.word 0x0001b800 0xfffc5c00 0x0008b000 0x00030400 
.word 0xffefd800 0x0018a000 
