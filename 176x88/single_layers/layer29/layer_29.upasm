.short 0xffc8 0xff4c 0x0045 0xff67 0x003f 0xff5a 0xff48 0x002d 
.short 0xfefe 0x0013 0x00e4 0xff79 0xfead 0x0035 0x005f 0x007f 
.short 0xff68 0xffdf 0x0057 0xff48 0xffd7 0xfe45 0x0096 0x00a2 
.short 0x00d6 0xff7d 0xffcf 0x0064 0x008b 0x010a 0x0038 0xff0b 
