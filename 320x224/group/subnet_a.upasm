subnet_a:
	sv tmp_rp_adr1 rp

	lcs t0 subnet_a_params
	lw shuffle_w t0 0	// w
	lw shuffle_h t0 4 	// h
	lcs t0 subnet_a_io_addr
	lw shuffle_input_adr t0 0
	lw shuffle_output_adr t0 4
	lcs t0 subnet_a_func
	lw t1 t0
	call t1

	
	lcs t0 subnet_a_params
	lw conv1_w t0 0		// w
	lw conv1_h t0 4 	// h

	lw t1 t0 8
	sl conv1_in_stride t1 2
	sl conv1_out_stride t1 1

	lcs t0 subnet_a_io_addr
	lw conv1_in_adr t0 4
	inc conv1_in_adr conv1_out_stride
	lw conv1_out_adr t0 8

	lcs t0 subnet_a_kernle_bias_addr
	lw conv1_kernel_adr t0 0
	lw conv1_bias_adr t0 4

	lcs t0 subnet_a_func
	lw t1 t0 4
	call t1




	lcs t0 subnet_a_params
	lw dwconv_out_w t0 0		// w
	lw dwconv_out_h t0 4 		// h
	mov dwconv_in_w dwconv_out_w
	mov dwconv_in_h dwconv_out_h
	lw dwconv_c t0 8

	lcs t0 subnet_a_io_addr
	lw dwconv_in_adr t0 8
	lw dwconv_out_adr t0 12
	
	lcs t0 subnet_a_kernle_bias_addr
	lw dwconv_kernel_adr t0 8
	lw dwconv_bias_adr t0 12
	call dwconv3


	lcs t0 subnet_a_params
	lw conv1_w t0 0		// w
	lw conv1_h t0 4 	// h

	lw t1 t0 8
	sl conv1_in_stride t1 1
	sl conv1_out_stride t1 2

	lcs t0 subnet_a_io_addr
	lw conv1_in_adr t0 12	
	lw conv1_out_adr t0 16
	inc conv1_out_adr conv1_in_stride

	lcs t0 subnet_a_kernle_bias_addr
	lw conv1_kernel_adr t0 16
	lw conv1_bias_adr t0 20

	lcs t0 subnet_a_func
	lw t1 t0 8
	call t1

	lv rp tmp_rp_adr1
	ret
