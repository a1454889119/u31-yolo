	lcs ptr0 subnet_a_params
	nop
	sw ptr0 10 	// w
	sw ptr0 7 	// h
	sw ptr0 48 	// c
	sv ptr0 shuffle_96
	sv ptr0 conv1_48_whc
	sv ptr0 conv1_48
	svw ptr0, SUBNET_A_10X7_ADDR_A
	svw ptr0, SUBNET_A_10X7_ADDR_B
	svw ptr0, SUBNET_A_10X7_ADDR_C
