#define t0 r20
#define t1 r21

subnet_a_params:
.word 0 // w
.word 0 // h
.word 0 // c
subnet_a_func:
.word 0 // shuffle
.word 0 // conv1_whc
.word 0 // conv1
subnet_a_io_addr:
.word 0 0 0 0 0 	// shuffle in / shuffle out / conv1 out / conv3 out / conv1 out
subnet_a_kernle_bias_addr:
.word 0 0 0 0 0 0

group3:
	sv tmp_rp_adr0 rp
	lcs ptr0 subnet_a_params
	nop
	sw ptr0 40 	// w
	sw ptr0 28 	// h
	sw ptr0 12 	// c
	sv ptr0 shuffle_24
	sv ptr0 conv1_12_whc
	sv ptr0 conv1_12
	svw ptr0, SUBNET_A_40X28_ADDR_B
	svw ptr0, SUBNET_A_40X28_ADDR_A
	svw ptr0, SUBNET_A_40X28_ADDR_C
	svw ptr0, SUBNET_A_40X28_ADDR_D
	svw ptr0, SUBNET_A_40X28_ADDR_A
	svw ptr0, LAYER_16_KERNEL_ADDR
	svw ptr0, LAYER_16_BIAS_ADDR
	svw ptr0, LAYER_17_KERNEL_ADDR
	svw ptr0, LAYER_17_BIAS_ADDR
	svw ptr0, LAYER_18_KERNEL_ADDR
	svw ptr0, LAYER_18_BIAS_ADDR

	call subnet_a
	lv rp tmp_rp_adr0
	ret

