entry:
	call psram_init_APS3208K

	lc r30,0x09000040
	sw r30,3

	lc maxp_in_adr PSRAM_LAYER_0_OUTPUT
	lc maxp_out_adr layer1_out_data
	call maxpool

	lcs conv1_w 80
	lcs conv1_h 56
	// 输入8通道, 输出8通道
	lcs conv1_in_stride 16
	lcs conv1_out_stride 16
	lc conv1_in_adr layer1_out_data
	lc conv1_out_adr conv3_in_data
	lc conv1_bias_adr layer6_bias
	lc conv1_kernel_adr layer6_kernel
	call conv1_8_whc

	lcs dwconv_out_w 40
	lcs dwconv_out_h 28
	lcs dwconv_in_w 80
	lcs dwconv_in_h 56
	lcs dwconv_c 8
	lc  dwconv_in_adr conv3_in_data
	lc  dwconv_out_adr conv3_out_data
	lc  dwconv_bias_adr layer7_bias
	lc  dwconv_kernel_adr layer7_kernel
	call dwconv3

	lcs conv1_w 40
	lcs conv1_h 28
	// 输入8通道, 输出24通道中的前8通道
	lcs conv1_in_stride 16
	lcs conv1_out_stride 48
	lc conv1_in_adr conv3_out_data
	lc conv1_out_adr group0_out_data
	lc conv1_bias_adr layer8_bias
	lc conv1_kernel_adr layer8_kernel
	call conv1_8

	lc r30,0x09000040
	lw r31,r30
	
	hlt