.short 0xffb9 0x0000 0x0000 0x0000 0x0000 0x0000 0x0000 0x0000 
.short 0xfeff 0xfe92 0xfedd 0xff78 0xfeba 0xfea8 0xff5a 0xff25 
.short 0xff88 0x0000 0x0000 0x0000 0x0000 0x0000 0x0000 0x0000 
.short 0xff0e 0xfe13 0x003e 0xfdde 0xfd71 0xfe7d 0xfe76 0xff1f 
.short 0xff0a 0x0000 0x0000 0x0000 0x0000 0x0000 0x0000 0x0000 
.short 0x009e 0x0069 0x007b 0x012b 0x021c 0x00df 0x0030 0x0046 
.short 0x0039 0x0000 0x0000 0x0000 0x0000 0x0000 0x0000 0x0000 
.short 0xff82 0x010f 0x009c 0x0192 0x04db 0x0189 0x0066 0x0243 
.short 0xff50 0x0000 0x0000 0x0000 0x0000 0x0000 0x0000 0x0000 
