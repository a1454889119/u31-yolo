#include maxpool.upinc
#include conv1.upinc
#include dwconv.upinc

@import conv1_8_whc
@import conv1_8
@import maxpool
@import dwconv3
@import init_psram
@import psram_init_APS3208K

.align 16
layer1_out_data:
.reserve 71680

group0_out_data:
.reserve 53760

conv3_in_data:
.reserve 71680

conv3_out_data:
.reserve 17920

.align 16
layer6_kernel:
.short 0xff21 0xfdca 0xfe79 0xff62 0xfe6e 0xff8a 0xfff3 0xff43 
.short 0xff3b 0xfd46 0x022c 0xffff 0xfb14 0x06ad 0x0009 0x001e 
