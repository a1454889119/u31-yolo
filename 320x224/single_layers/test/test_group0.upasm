.short 0xff03 0x0000 0x0000 0x0000 0x0000 0x0000 0x0000 0x0000 

layer7_bias:
.word 0x0000f07d 0x00021804 0x00063625 0x00032cf6 0xffffff9b 0xfff56106 0xffe387c5 0x0007b59e 

layer8_kernel:
.short 0xffe6 0x0328 0x00cb 0x00dc 0xffbd 0xff3e 0xff6e 0x01cc 
.short 0x0048 0x004b 0xfee3 0x0145 0x0014 0x011e 0x0192 0xfe0f 
.short 0x00e0 0x002d 0xff5e 0x01ae 0x0054 0xff63 0x0125 0x0098 
.short 0x0011 0x0169 0x0264 0x02ea 0x0037 0x0066 0x0183 0xfdfb 
