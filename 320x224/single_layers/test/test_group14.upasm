	lc  dwconv_in_adr conv3_in_data
	lc  dwconv_out_adr conv3_out_data
	lc  dwconv_bias_adr l2_bias
	lc  dwconv_kernel_adr l2_kernel
	call dwconv3

	lcs conv1_w 10
	lcs conv1_h 7
	// 输入48通道, 输出96通道的后48通道
	lcs conv1_in_stride 96
	lcs conv1_out_stride 192
	lc conv1_in_adr conv3_out_data
	lc conv1_out_adr, shuffle_out_data + 96
	lc conv1_bias_adr l3_bias
	lc conv1_kernel_adr l3_kernel
	call conv1_48

	lc r30,0x09000040
	lw r31,r30
	hlt