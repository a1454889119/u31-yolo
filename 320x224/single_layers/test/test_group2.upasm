entry:

	
	lc r30,0x09000040
	sw r30,3

	lcs shuffle_w 40
	lcs shuffle_h 28
	lc  shuffle_input_adr layer10_input_data
	lc  shuffle_output_adr shuffle_out_data
	call shuffle_24
	
	lcs conv1_w 40
	lcs conv1_h 28
	// 输入24通道的后12通道, 输出12通道
	lcs conv1_in_stride 48
	lcs conv1_out_stride 24
	lc conv1_in_adr, shuffle_out_data + 24
	lc conv1_out_adr conv3_in_data
	lc conv1_bias_adr l1_bias
	lc conv1_kernel_adr l1_kernel
	call conv1_12_whc

	lcs dwconv_out_w 40
	lcs dwconv_out_h 28
	lcs dwconv_in_w 40
	lcs dwconv_in_h 28
	lcs dwconv_c 12
	lc  dwconv_in_adr conv3_in_data
	lc  dwconv_out_adr conv3_out_data
	lc  dwconv_bias_adr l2_bias
	lc  dwconv_kernel_adr l2_kernel
	call dwconv3

	lcs conv1_w 40
	lcs conv1_h 28
	// 输入12通道, 输出24通道的后12通道
	lcs conv1_in_stride 24
	lcs conv1_out_stride, 48
	lc conv1_in_adr conv3_out_data
	lc conv1_out_adr, layer10_input_data + 24
	lc conv1_bias_adr l3_bias
	lc conv1_kernel_adr l3_kernel
	call conv1_12

	lc r30,0x09000040
	lw r31,r30

	hlt