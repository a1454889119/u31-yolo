entry:

	lc r30,0x09000040
	sw r30,3

	lcs conv1_w 80
	lcs conv1_h 56
	// 输入8通道, 输出12通道
	lcs conv1_in_stride 16
	lcs conv1_out_stride 24
	lc conv1_in_adr layer1_output
	lc conv1_out_adr layer2_out_data
	lc conv1_bias_adr layer2_bias
	lc conv1_kernel_adr layer2_kernel
	call conv1_8_12

	lcs dwconv_out_w 40
	lcs dwconv_out_h 28
	lcs dwconv_in_w 80
	lcs dwconv_in_h 56
	lcs dwconv_c 12
	lc  dwconv_in_adr layer2_out_data
	lc  dwconv_out_adr layer1_output
	lc  dwconv_bias_adr layer3_bias
	lc  dwconv_kernel_adr layer3_kernel
	call dwconv3

	lcs conv1_w 40
	lcs conv1_h 28
	// 输入12通道, 输出24通道中的后16通道
	lcs conv1_in_stride 24
	lcs conv1_out_stride, 48
	lc conv1_in_adr layer1_output
	lc conv1_out_adr, group1_out_data + 32
	lc conv1_bias_adr layer4_bias
	lc conv1_kernel_adr layer4_kernel
	call conv1_12_16

	lc r30,0x09000040
	lw r31,r30
	hlt

