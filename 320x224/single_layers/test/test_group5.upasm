entry:
	lc r30,0x09000040
	sw r30,3

	//----左边----
	lcs conv1_w 40
	lcs conv1_h 28
	// 输入24通道, 输出24通道
	lcs conv1_in_stride 48
	lcs conv1_out_stride 48
	lc conv1_in_adr, layer24_output
	lc conv1_out_adr conv3_in_data
	lc conv1_bias_adr l1_bias
	lc conv1_kernel_adr l1_kernel
	call conv1_24_whc
	
	lcs dwconv_out_w 20
	lcs dwconv_out_h 14
	lcs dwconv_in_w 40
	lcs dwconv_in_h 28
	lcs dwconv_c 24
	lc  dwconv_in_adr conv3_in_data
	lc  dwconv_out_adr conv3_out_data
	lc  dwconv_bias_adr l2_bias
	lc  dwconv_kernel_adr l2_kernel
	call dwconv3

	lcs conv1_w 20
	lcs conv1_h 14
	// 输入24通道, 输出48通道的前24通道
	lcs conv1_in_stride 48
	lcs conv1_out_stride 96
	lc conv1_in_adr conv3_out_data
	lc conv1_out_adr group5_out_data
	lc conv1_bias_adr l3_bias
	lc conv1_kernel_adr l3_kernel
	call conv1_24

	//----右边----
	lcs conv1_w 40
	lcs conv1_h 28
	// 输入24通道, 输出24通道
	lcs conv1_in_stride 48
	lcs conv1_out_stride 48
	lc conv1_in_adr, layer24_output
	lc conv1_out_adr conv3_in_data
	lc conv1_bias_adr r1_bias
	lc conv1_kernel_adr r1_kernel
	call conv1_24_whc
	
	lcs dwconv_out_w 20
	lcs dwconv_out_h 14
	lcs dwconv_in_w 40
	lcs dwconv_in_h 28
	lcs dwconv_c 24
	lc  dwconv_in_adr conv3_in_data
	lc  dwconv_out_adr conv3_out_data
	lc  dwconv_bias_adr r2_bias
	lc  dwconv_kernel_adr r2_kernel
	call dwconv3

	lcs conv1_w 20
	lcs conv1_h 14
	// 输入24通道, 输出48通道的后24通道
	lcs conv1_in_stride 48
	lcs conv1_out_stride 96
	lc conv1_in_adr conv3_out_data
	lc conv1_out_adr, group5_out_data+48
	lc conv1_bias_adr r3_bias
	lc conv1_kernel_adr r3_kernel
	call conv1_24

	lc r30,0x09000040
	lw r31,r30

	hlt


