.align 4
APP_TMP_BUF_ADDR:
    .word 0 0 0 0

.align 4
OTA_ENTER_BUF:
    .byte 0xFE 0x68 0x1D 0x02 0x91 0xAA 0xc2 0x16  // 进入OTA指令

.align 4
OTA_RESP_BUF:
    .byte 0xFE 0x68 0x9D 0x03 0x91 0xAA 0x00 0x43 0x16 0 0 0

// .align 4
// SPIOUT_OFF_BUF:
//     .byte 0xFE 0x68 0x1D 0x03 0x91 0x11 0x00 0x2A 0x16 0 0 0  // 设置SPI模式关闭

// .align 4
// SPIOUT_ON_BUF:
//     .byte 0xFE 0x68 0x1D 0x03 0x91 0x11 0x01 0x2B 0x16 0 0 0  // 设置SPI模式打开

.align 4
QUE_VER_BUF:
    .byte 0xFE 0x68 0x1D 0x03 0x91 0x12 0x00 0x2B 0x16 0 0 0  // 查询版本号

// .align 4
// SPIOUT_RESP_BUF:
//     .byte 0xFE 0x68 0x9D 0x03 0x91 0x10 0x00 0xA9 0x16 0 0 0  // SPI模式设置响应指令

@export UART_TMP_BUF
.align 4
UART_TMP_BUF:
    .word 0 0 0 0

.align 4
UART_RX_CNT_BUF:
    .word 0
#endif