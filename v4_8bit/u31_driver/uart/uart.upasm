#if OTA_ENABLE==1
// #include "project.upinc"
@import APP_VERSION_STR

#define SPIOUT_MOD0 0x55555500 // SPI模式门控模式
#define SPIOUT_MOD1 0x55555501 // SPI模式连续模式

#define SPIOUT_OFF 0x55555500
#define SPIOUT_ON  0x55555501

$func memset(in addr, in value, in len)
$func memcmp(in addr1, in addr2, in len, out reg_result)

$func APP_UART0_RX_IRQ_Handler()

// #define UPDATE_MAGIC_BUF_ADDR 0x3f00     //保存升级标志的地址flash 256K的最后一页
#define UPDATE_MAGIC_BUF_ADDR 0x7ff00     //保存升级标志的地址flash 512K的最后一页
#define UPDATE_MAGIC_VALUE    0xA5A5A5A5  //升级标志的值
$func flash_Write_Enable()
$func flash_Page_Erase(in flash_addr)
$func flash_Read_SR1(in ram_addr, out reg_result)
$func flash_w_wait()
$func flash_Page_Program(in flash_addr, in ram_addr, in len)
// $func flash_Normal_Read(in flash_addr, in ram_addr, in length)

IRQ_TBL_UART:
    $push_regs rp rj rv r1
    lvw r1 0x0900081C

    ifu r1 eb 4 {
        APP_UART0_RX_IRQ_Handler()
    }

    // ifu r1 eb 7 {
    //     UART3_RX_IRQ_Handler()
    // }
    
    $pop_regs rp rj rv r1
iret

$func enable_uart_irq() {
    lc iv10 IRQ_TBL_UART     // 设置中断向量表
    bit_set cr cr 10         // 使能串口中断控制器
}


/**
 * 串口0 发送数据
 * addr 缓存地址 
 * len 表示发送的bytes
 * [31:20]   UART0接收字节数, 写寄存器启动一次发送
 * [15:0]    UART0发送数据缓存地址
 */
$func uart0_tx_data_block(in addr, in len) {
    reg x0 x1
    nop
// _loop_uart0_busy:
//     lvw x0 0x0900082c
//     ifu x0 eb 4 {      // UART0发送忙标志
//         jmp _loop_uart0_busy     
//     }

    load_reg x0 len
    load_reg x1 addr
    sl x0 x0 20
    or x0 x0 x1
    svw 0x09000804 x0
    hlt 9
}

/**
 * 串口0 接收数据
 * addr 缓存地址 
 * len  表示发送的bytes
 *
 * 0x09000808
 * [31:20]   UART0接收字节数, 写寄存器启动一次接收
 * [15:0]    UART0接收数据缓存地址
 * 
 * 0x09000840
 * [25:16]   UART1接收超时计数阈值
 * [9:0]     UART0接收超时计数阈值
 */
$func uart0_rx_data(in addr, in len) {
    reg x0 x1 x2 x3
    nop
    load_reg x0 len
    load_reg x1 addr

    svw 0x09000840 0x3ff  //设置超时的计数器

    sl x0 x0 20
    or x0 x0 x1
    svw 0x09000808 x0
    nop
}

$func APP_UART0_RX_IRQ_Handler() {
    reg x1 x2 x3

    cache_clr

    lvw x1 UART_RX_CNT_BUF  // 每次起中断累加1
    add x1 x1 1
    svw UART_RX_CNT_BUF x1

    memcmp(UART_TMP_BUF, OTA_ENTER_BUF, 8, x2) // 0xFE 0x68 0x1D 0x02 0x91 0xAA 0xc2 0x16
    ifu x2 == 1 {            
        flash_Write_Enable()
        flash_Page_Erase(UPDATE_MAGIC_BUF_ADDR)
        flash_w_wait()
        
        flash_Write_Enable()
        svw APP_TMP_BUF_ADDR 0xA5A5A5A5
        flash_Page_Program(UPDATE_MAGIC_BUF_ADDR, APP_TMP_BUF_ADDR, 4)
        flash_w_wait()
        
        uart0_tx_data_block(OTA_RESP_BUF, 9)   // 发送resp
        hlt 200000
        svw 0x09000024 1 // 重启
    }

    // memcmp(UART_TMP_BUF, SPIOUT_OFF_BUF, 9, x2)
    // ifu x2 == 1 {
    //     flash_Normal_Read(UPDATE_MAGIC_BUF_ADDR, APP_TMP_BUF_ADDR, 12)

    //     flash_Write_Enable()
    //     flash_Page_Erase(UPDATE_MAGIC_BUF_ADDR)
    //     flash_w_wait()
        
    //     flash_Write_Enable()
    //     svw, APP_TMP_BUF_ADDR, 0xffffffff
    //     svw, APP_TMP_BUF_ADDR+8, SPIOUT_OFF
    //     flash_Page_Program(UPDATE_MAGIC_BUF_ADDR, APP_TMP_BUF_ADDR, 12)
    //     flash_w_wait()

    //     uart0_tx_data_block(SPIOUT_RESP_BUF, 9)
    //     hlt 200000
    //     svw 0x09000024 1 // 重启
    // }

    // memcmp(UART_TMP_BUF, SPIOUT_ON_BUF, 9, x2)
    // ifu x2 == 1 {
    //     flash_Normal_Read(UPDATE_MAGIC_BUF_ADDR, APP_TMP_BUF_ADDR, 12)

    //     flash_Write_Enable()
    //     flash_Page_Erase(UPDATE_MAGIC_BUF_ADDR)
    //     flash_w_wait()
        
    //     flash_Write_Enable()
    //     svw, APP_TMP_BUF_ADDR, 0xffffffff
    //     svw, APP_TMP_BUF_ADDR+8, SPIOUT_ON
    //     flash_Page_Program(UPDATE_MAGIC_BUF_ADDR, APP_TMP_BUF_ADDR, 12)
    //     flash_w_wait()

    //     uart0_tx_data_block(SPIOUT_RESP_BUF, 9)
    //     hlt 200000
    //     svw 0x09000024 1 // 重启
    // }

    memcmp(UART_TMP_BUF, QUE_VER_BUF, 9, x2)
    ifu x2 == 1 {
        uart0_tx_data_block(APP_VERSION_STR, 32)
        hlt 200000;
    }

    ifu x1 >= 63 {
        svw 0x09000800 0x00400016 // 取消串口接收中断
    }
    memset(UART_TMP_BUF, 0, 16)
}

