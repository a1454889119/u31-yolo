$func flash_Write_Enable() {
    svw 0x09000700, 0x3012500
    svw 0x09000704, 0x103
    svw 0x09000708, 0xffffffff
    svw 0x0900070c, 0xffffffff
    svw 0x09000710, 0x06000000
    hlt 6
}

$func flash_Page_Erase(in flash_addr) {
    reg x1
    nop
    load_reg x1 flash_addr
    svw 0x09000700, 0x30125b0
    svw 0x09000704, 0x103
    svw 0x09000708, x1
    svw 0x0900070c, 0xffffffff
    svw 0x09000710, 0x81000000
    hlt 6
}

$func flash_Read_SR1(in ram_addr, out reg_result) {
    reg x1 x2
    nop
    load_reg x1 ram_addr
    svw 0x09000700, 0x3012500
    svw 0x09000704, 0x103
    svw 0x09000708, 0xffffffff
    svw 0x0900070c, x1
    svw 0x09000710, 0x5000001
    hlt 6

    cache_clr
    lw x2 x1
    set_var reg_result x2
    nop
}

$func flash_w_wait() {
    reg x1
    flash_Read_SR1(APP_TMP_BUF_ADDR, x1)
    whileu x1 eb 0 {
        flash_Read_SR1(APP_TMP_BUF_ADDR, x1)
    }
}

// 写一个page 长度固定为256字节
$func flash_Page_Program(in flash_addr, in ram_addr, in len) {
    reg x1 x2 x3
    nop
    load_reg x1 flash_addr
    load_reg x2 ram_addr
    load_reg x3 len

    svw 0x09000700, 0x30125b0
    svw 0x09000704, 0x103
    svw 0x09000708, x1
    svw 0x0900070c, x2

    lc x2 0x02800000
    or x3 x2 x3
    svw 0x09000710, x3
    hlt 6
}

